# ===========================================================================
# Chitin Shell — Secure Proxy Container (Execute Layer)
#
# This container:
#   - Holds ALL API keys and credentials (vault)
#   - Executes verified Intents against real external APIs
#   - Sanitizes all output before returning results
#   - Has external network access
#
# ONLY the policy engine can reach this container.
# The agent container CANNOT reach it — that is the core security guarantee.
# ===========================================================================

# --- Stage 1: Build ---
FROM node:20-slim AS builder

WORKDIR /build

# Copy core package source
COPY packages/core/package.json packages/core/tsconfig.json ./packages/core/
COPY packages/core/src/ ./packages/core/src/

# Copy root tsconfig
COPY tsconfig.json ./

# Copy docker service source
COPY docker/services/proxy-server.ts ./docker/services/
COPY docker/services/shared/ ./docker/services/shared/

# Copy docker tsconfig and package.json (type: module)
COPY docker/tsconfig.docker.json docker/package.json ./docker/

# Install dependencies and build core
WORKDIR /build/packages/core
RUN npm install && npm run build

# Build docker services
WORKDIR /build/docker
RUN npm install typescript@5.7 tsx @types/node@20 && \
    mkdir -p node_modules/@chitin-id/shell-core/dist && \
    cp -r /build/packages/core/dist/* node_modules/@chitin-id/shell-core/dist/ && \
    cp /build/packages/core/package.json node_modules/@chitin-id/shell-core/ && \
    npx tsc -p tsconfig.docker.json

# --- Stage 2: Production ---
FROM node:20-slim AS production

# Security: run as non-root
RUN groupadd -r chitin && useradd -r -g chitin -s /bin/false chitin

WORKDIR /app

# Copy compiled core package (preserve dist/ structure for package.json exports)
COPY --from=builder /build/packages/core/dist/ ./node_modules/@chitin-id/shell-core/dist/
COPY --from=builder /build/packages/core/package.json ./node_modules/@chitin-id/shell-core/

# Copy compiled service + ESM package.json
COPY --from=builder /build/docker/dist/proxy-server.js ./
COPY --from=builder /build/docker/dist/shared/ ./shared/
COPY --from=builder /build/docker/services/package.json ./

# Create vault config directory (will be mounted as volume)
RUN mkdir -p /app/vault && chown chitin:chitin /app/vault

# Create tmp directory
RUN mkdir -p /tmp/chitin && chown chitin:chitin /tmp/chitin

# Switch to non-root user
USER chitin

ENV NODE_ENV=production
ENV PROXY_PORT=3200
ENV VAULT_TYPE=memory

# API keys are passed via environment variables or mounted vault file
# PROXY_OPENAI_KEY, PROXY_ANTHROPIC_KEY, PROXY_SLACK_TOKEN, etc.

EXPOSE 3200

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
  CMD node -e "const h=require('http');h.get('http://localhost:3200/health',r=>{process.exit(r.statusCode===200?0:1)}).on('error',()=>process.exit(1))"

CMD ["node", "proxy-server.js"]
