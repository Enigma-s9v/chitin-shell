# ===========================================================================
# Chitin Shell — Proxy Container Environment Variables
#
# Copy this file to .env and fill in your real credentials:
#   cp example.env .env
#
# IMPORTANT: These credentials exist ONLY in the proxy container.
# The agent container has NO access to these values.
# ===========================================================================

# --- API Credentials (ONLY in proxy container) ---

# OpenAI
PROXY_OPENAI_KEY=sk-your-openai-key

# Anthropic
PROXY_ANTHROPIC_KEY=sk-ant-your-anthropic-key

# Slack
PROXY_SLACK_TOKEN=xoxb-your-slack-token

# GitHub
PROXY_GITHUB_TOKEN=ghp-your-github-token

# --- Service Configuration ---

# Policy config file path (inside policy container)
# POLICY_CONFIG_PATH=/app/config/policy.json

# Vault type: memory (default), file
VAULT_TYPE=memory

# --- Ports ---

AGENT_PORT=3000
POLICY_PORT=3100
PROXY_PORT=3200
