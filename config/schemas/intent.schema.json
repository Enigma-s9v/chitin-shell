{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chitin.id/schemas/intent/v1.0",
  "title": "Chitin Shell Intent v1.0",
  "description": "A structured, signed intent produced by an AI agent",
  "type": "object",
  "required": ["version", "intent_id", "agent_did", "timestamp", "action", "context", "nonce", "signature"],
  "properties": {
    "version": { "const": "1.0" },
    "intent_id": { "type": "string", "minLength": 1 },
    "agent_did": { "type": "string", "pattern": "^did:" },
    "timestamp": { "type": "string", "format": "date-time" },
    "action": {
      "type": "object",
      "required": ["type", "params"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "params": { "type": "object" }
      },
      "additionalProperties": false
    },
    "context": {
      "type": "object",
      "required": ["triggered_by", "session_id"],
      "properties": {
        "triggered_by": { "enum": ["user_message", "scheduled", "webhook", "agent_internal"] },
        "session_id": { "type": "string", "minLength": 1 },
        "conversation_hash": { "type": "string" },
        "parent_intent_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "nonce": { "type": "integer", "minimum": 0 },
    "signature": { "type": "string", "pattern": "^[0-9a-fA-F]+$" }
  },
  "additionalProperties": false
}
